# Managed by chezmoi — edit via: chezmoi edit ~/.ssh/config

# --- Global defaults ---
Host *
{{- if ne .profile "work" }}
  # Use the XDG-respecting key location
  IdentityFile ~/.ssh/id_ed25519
{{- end }}
  # Reuse existing connections — faster subsequent connections to the same host
  ControlMaster auto
  ControlPath ~/.ssh/control/%r@%h:%p
  ControlPersist 2m
  # Reduce disconnections on idle connections
  ServerAliveInterval 60
  ServerAliveCountMax 3
{{ if eq .chezmoi.os "darwin" }}
  # macOS Keychain — store passphrase on first use, never prompted again
  UseKeychain yes
  AddKeysToAgent yes
{{ end }}

# --- Personal hosts ---
Host github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes

{{ if eq .profile "work" -}}
{{ include "private_dot_ssh/encrypted_config-work.age" | decrypt -}}
{{ end -}}
