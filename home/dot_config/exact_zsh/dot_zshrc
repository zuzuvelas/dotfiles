# shellcheck disable=SC1090

# Shell options
source "$ZDOTDIR/options.zsh"

# Environment
source "$ZDOTDIR/exports.zsh"

# Completions — must run before sheldon so compdef is available for plugins
source "$ZDOTDIR/completions.zsh"

# Plugins
eval "$(sheldon source)"

# Word movement in vi insert mode
bindkey -M viins '\eb' backward-word
bindkey -M viins '\ef' forward-word

# Dircycle — bind Meta+↑/↓ in vi insert mode
# Must come after sheldon so insert-cycled{left,right} widgets exist
bindkey -M viins '\e[1;3A' insert-cycledleft
bindkey -M viins '\e[1;3B' insert-cycledright

# Word delete — Option+Backspace in vi insert mode
bindkey -M viins '\e^?' backward-kill-word

# Aliases
for f in "$ZDOTDIR/aliases"/*.zsh; do source "$f"; done

# Functions
for f in "$ZDOTDIR/functions"/*.zsh; do source "$f"; done

# fzf — shell integration for Ctrl+T (files) and Alt+C (dirs)
# Must come before atuin so atuin can override fzf's Ctrl+R binding
eval "$(fzf --zsh)"

# Toolchain
eval "$(mise activate zsh)"
eval "$(zoxide init zsh)"
eval "$(thefuck --alias)"

# History — overrides fzf's Ctrl+R with atuin's fuzzy search
eval "$(atuin init zsh)"

# Exclude AI-agent-run commands from autosuggestions, while
# keeping them in atuin history
_zsh_autosuggest_strategy_atuin() {
    suggestion=$(ATUIN_QUERY="$1" atuin search --cmd-only --limit 1 --search-mode prefix --author '$all-user' 2>/dev/null)
}

# Prompt
source "$ZDOTDIR/prompt.zsh"
