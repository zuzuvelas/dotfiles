# Shell options
source "$ZDOTDIR/options.zsh"

# Environment
source "$ZDOTDIR/exports.zsh"

# Bootstrap compinit before plugins so plugins can call compdef at source time.
# completions.zsh runs a full compinit after sheldon — this -C call just makes
# compdef available early.
autoload -Uz compinit && compinit -C

# Plugins — must load before completions so plugins can contribute to $fpath
eval "$(sheldon source)"

# Dircycle — bind Meta+←/→ in vi insert mode
# Must come after sheldon so insert-cycled{left,right} widgets exist
bindkey -M viins '\eb' insert-cycledleft
bindkey -M viins '\ef' insert-cycledright

# Completions
source "$ZDOTDIR/completions.zsh"

# Aliases
source "$ZDOTDIR/aliases/general.zsh"
source "$ZDOTDIR/aliases/git.zsh"
source "$ZDOTDIR/aliases/docker.zsh"

# Functions
source "$ZDOTDIR/functions.zsh"

# fzf — shell integration for Ctrl+T (files) and Alt+C (dirs)
# Must come before atuin so atuin can override fzf's Ctrl+R binding
eval "$(fzf --zsh)"

# Toolchain
eval "$(mise activate zsh)"
eval "$(zoxide init zsh)"
eval "$(thefuck --alias)"

# History — overrides fzf's Ctrl+R with atuin's fuzzy search
eval "$(atuin init zsh)"

# Prompt
source "$ZDOTDIR/prompt.zsh"
